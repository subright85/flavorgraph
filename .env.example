# Pairfect environment template

# === Database ===
# Local dev (default if unset): file:./flavorgraph.db (committed read-only seed)
# Production (Turso libSQL): set both env vars when migrating off the bundled file
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOi...

# === AI explanation (optional) ===
# Required only for the pair-info Claude-generated explanation feature.
# Without this set, the API returns a static fallback (works, just less rich).
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=
